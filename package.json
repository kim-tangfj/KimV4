{
  "name": "kim-storyboard-assistant",
  "version": "1.0.4",
  "description": "Kim 多级分镜提示词助手 - 面向视频创作者、AI 内容生成师的多级分镜管理与提示词自动化生成工具",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "keywords": [
    "electron",
    "video-production",
    "storyboard",
    "ai-prompts"
  ],
  "author": "KimV4",
  "license": "MIT",
  "build": {
    "appId": "com.kimv4.storyboard",
    "productName": "KimStoryboard",
    "artifactName": "Kim-Setup-${version}.exe",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "index.html",
      "styles.css",
      "package.json",
      "!**/node_modules/.bin/**",
      "!**/*.md"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/electron-updater/**",
      "**/*.node"
    ],
    "extraResources": [
      {
        "from": "assets/default",
        "to": "default"
      }
    ],
    "forceCodeSigning": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kim 分镜助手",
      "installerIcon": "assets/icon.png",
      "uninstallerIcon": "assets/icon.png",
      "installerHeaderIcon": "assets/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "kim-tangfj",
      "repo": "KimV4",
      "releaseType": "draft"
    }
  }
}
